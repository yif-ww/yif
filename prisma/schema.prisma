generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Better Auth required models ────────────────────────────────────────────

model User {
  id            String   @id
  name          String
  email         String   @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime
  role          String   @default("member")

  // Better Auth admin plugin
  banned     Boolean?  @default(false)
  banReason  String?
  banExpires DateTime?

  // Extended profile
  phone         String?
  gender        String?
  continent     String?
  country       String?
  stateProvince String?
  cityDistrict  String?
  bio           String?

  // Notification preferences
  notifEventInvites     Boolean @default(true)
  notifNewsletter       Boolean @default(true)
  notifDonationReceipts Boolean @default(true)
  notifMemberUpdates    Boolean @default(true)
  notifScholarshipNews  Boolean @default(true)

  sessions                Session[]
  accounts                Account[]
  member                  Member?
  tickets                 Ticket[]
  donations               Donation[]
  scholarshipApplications ScholarshipApplication[]
  transactions            Transaction[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Better Auth admin plugin
  impersonatedBy String?

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  @@map("account")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
}

// ─── App models ─────────────────────────────────────────────────────────────

enum MembershipTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  PLATINUM
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  SUSPENDED
  PENDING
}

model Member {
  id               String          @id @default(cuid())
  userId           String          @unique
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier             MembershipTier  @default(SILVER)
  status           MembershipStatus @default(PENDING)
  joinedAt         DateTime        @default(now())
  expiresAt        DateTime?
  membershipNumber String?         @unique
  paystackRef      String?
  // Scheduled tier change: set for downgrades, applied at next renewal
  pendingTier      MembershipTier?

  @@map("member")
}

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  date        DateTime
  location    String?
  imageUrl    String?
  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets Ticket[]

  @@map("event")
}

enum TicketStatus {
  PENDING
  CONFIRMED
  CANCELLED
  USED
}

model Ticket {
  id         String       @id @default(cuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    String
  event      Event        @relation(fields: [eventId], references: [id])
  tierName   String
  quantity   Int          @default(1)
  status     TicketStatus @default(PENDING)
  reference  String       @unique
  amountPaid Decimal?     @db.Decimal(10, 2)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@map("ticket")
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Donation {
  id        String         @id @default(cuid())
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  cause     String
  amount    Decimal        @db.Decimal(10, 2)
  status    DonationStatus @default(PENDING)
  reference String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  @@map("donation")
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model ScholarshipApplication {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  cycle       String
  status      ApplicationStatus @default(DRAFT)
  formData    Json
  submittedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([userId, cycle])
  @@map("scholarship_application")
}

// ─── Transactions ───────────────────────────────────────────────────────────
// Single source of truth for every payment processed through Paystack.
// Records the full lifecycle (init → verify) including fees / channel / raw
// gateway response so the admin panel can show transparent financials.

enum TransactionPurpose {
  MEMBERSHIP
  TICKET
  DONATION
  OTHER
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  ABANDONED
  REVERSED
}

model Transaction {
  id              String             @id @default(cuid())
  provider        String             @default("paystack")
  reference       String             @unique
  providerTxId    String?            // Paystack numeric id (stored as string)
  purpose         TransactionPurpose @default(OTHER)
  status          TransactionStatus  @default(PENDING)

  // Money (all stored in NGN base units, not kobo, for human-readable reports)
  amount          Decimal            @db.Decimal(12, 2)
  fees            Decimal?           @db.Decimal(12, 2)
  netAmount       Decimal?           @db.Decimal(12, 2)
  currency        String             @default("NGN")

  // Channel info (card, bank, ussd, mobile_money, qr, bank_transfer, etc.)
  channel         String?
  cardBrand       String?
  cardLast4       String?
  cardBank        String?
  gatewayResponse String?
  ipAddress       String?

  // Customer
  customerEmail   String
  customerName    String?
  customerPhone   String?

  // Linkage — optional FKs (no relations, kept loose so a tx can exist
  // before/without the related domain row)
  userId          String?
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  memberId        String?
  ticketId        String?
  donationId      String?

  // Raw payloads for full transparency / audit
  metadata        Json?              // metadata sent to Paystack at init
  rawResponse     Json?              // full /transaction/verify response

  paidAt          DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([purpose])
  @@index([userId])
  @@index([createdAt])
  @@map("transaction")
}
